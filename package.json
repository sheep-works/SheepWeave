{
  "name": "sheep-weave",
  "displayName": "SheepWeave",
  "description": "AI Translation & Post-editing Assistant",
  "version": "0.0.6",
  "publisher": "sheepweave",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:shwvt",
    "onFileSystem:workspace"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sheepWeave.openPanel",
        "title": "SheepWeave: Open Panel"
      },
      {
        "command": "sheepWeave.prepare",
        "title": "SheepWeave: Prepare Project"
      },
      {
        "command": "sheepWeave.replaceWithTm1",
        "title": "SheepWeave: Apply TM 1"
      },
      {
        "command": "sheepWeave.replaceWithTm2",
        "title": "SheepWeave: Apply TM 2"
      },
      {
        "command": "sheepWeave.replaceWithTm3",
        "title": "SheepWeave: Apply TM 3"
      },
      {
        "command": "sheepWeave.replaceWithTm4",
        "title": "SheepWeave: Apply TM 4"
      },
      {
        "command": "sheepWeave.replaceWithTm5",
        "title": "SheepWeave: Apply TM 5"
      },
      {
        "command": "sheepWeave.replaceWithTb",
        "title": "SheepWeave: Apply Term"
      },
      {
        "command": "sheepWeave.replaceAllWithTb",
        "title": "SheepWeave: Apply Term Globally"
      },
      {
        "command": "sheepWeave.renameLikeReplace",
        "title": "SheepWeave: Rename-Like Replace"
      },
      {
        "command": "sheepWeave.confirmLine",
        "title": "SheepWeave: Confirm Line"
      },
      {
        "command": "sheepWeave.startAddTermSide",
        "title": "SheepWeave: Add Term (Side)"
      },
      {
        "command": "sheepWeave.confirmAddTermSide",
        "title": "SheepWeave: Confirm Term (Side)"
      },
      {
        "command": "sheepWeave.cancelAddTermSide",
        "title": "SheepWeave: Cancel Term (Side)"
      }
    ],
    "languages": [
      {
        "id": "shwvt",
        "aliases": [
          "SheepWeave Target"
        ],
        "extensions": [
          ".shwvt"
        ]
      },
      {
        "id": "shwvs",
        "aliases": [
          "SheepWeave Source"
        ],
        "extensions": [
          ".shwvs"
        ]
      },
      {
        "id": "shwv",
        "aliases": [
          "SheepWeave Text"
        ],
        "extensions": [
          ".shwv"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "keybindings": [
      {
        "command": "sheepWeave.openPanel",
        "key": "ctrl+alt+l",
        "when": "editorTextFocus"
      },
      {
        "command": "sheepWeave.replaceWithTm1",
        "key": "ctrl+shift+1",
        "when": "editorTextFocus && editorLangId == shwvt"
      },
      {
        "command": "sheepWeave.replaceWithTm2",
        "key": "ctrl+shift+2",
        "when": "editorTextFocus && editorLangId == shwvt"
      },
      {
        "command": "sheepWeave.replaceWithTm3",
        "key": "ctrl+shift+3",
        "when": "editorTextFocus && editorLangId == shwvt"
      },
      {
        "command": "sheepWeave.replaceWithTm4",
        "key": "ctrl+shift+4",
        "when": "editorTextFocus && editorLangId == shwvt"
      },
      {
        "command": "sheepWeave.replaceWithTm5",
        "key": "ctrl+shift+5",
        "when": "editorTextFocus && editorLangId == shwvt"
      },
      {
        "command": "sheepWeave.replaceWithTb",
        "key": "ctrl+shift+z",
        "when": "editorTextFocus && editorLangId == shwvt"
      },
      {
        "command": "sheepWeave.replaceAllWithTb",
        "key": "ctrl+shift+alt+z",
        "when": "editorTextFocus && editorLangId == shwvt"
      },
      {
        "command": "sheepWeave.replaceWithTm1",
        "key": "ctrl+shift+numpad1",
        "when": "editorTextFocus && editorLangId == shwvt"
      },
      {
        "command": "sheepWeave.replaceWithTm2",
        "key": "ctrl+shift+numpad2",
        "when": "editorTextFocus && editorLangId == shwvt"
      },
      {
        "command": "sheepWeave.replaceWithTm3",
        "key": "ctrl+shift+numpad3",
        "when": "editorTextFocus && editorLangId == shwvt"
      },
      {
        "command": "sheepWeave.replaceWithTm4",
        "key": "ctrl+shift+numpad4",
        "when": "editorTextFocus && editorLangId == shwvt"
      },
      {
        "command": "sheepWeave.replaceWithTm5",
        "key": "ctrl+shift+numpad5",
        "when": "editorTextFocus && editorLangId == shwvt"
      },
      {
        "command": "sheepWeave.renameLikeReplace",
        "key": "f2",
        "when": "editorTextFocus && editorLangId == shwvt"
      },
      {
        "command": "sheepWeave.confirmLine",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && editorLangId == shwvt"
      },
      {
        "command": "sheepWeave.startAddTermSide",
        "key": "ctrl+t",
        "when": "editorTextFocus && editorLangId == shwvt"
      },
      {
        "command": "sheepWeave.confirmAddTermSide",
        "key": "enter",
        "when": "editorTextFocus && editorLangId == shwvs && sheepWeave.addTermSideMode"
      },
      {
        "command": "sheepWeave.confirmAddTermSide",
        "key": "ctrl+t",
        "when": "editorTextFocus && editorLangId == shwvs && sheepWeave.addTermSideMode"
      },
      {
        "command": "sheepWeave.cancelAddTermSide",
        "key": "escape",
        "when": "editorTextFocus && (editorLangId == shwvs || editorLangId == shwvt) && sheepWeave.addTermSideMode"
      }
    ],
    "configuration": {
      "title": "SheepWeave",
      "properties": {
        "sheepWeave.sourceLang": {
          "type": "string",
          "default": "en-US",
          "enum": [
            "en-US",
            "ja-JP",
            "zh-CN"
          ]
        },
        "sheepWeave.targetLang": {
          "type": "string",
          "default": "ja-JP",
          "enum": [
            "en-US",
            "ja-JP",
            "zh-CN"
          ]
        },
        "sheepWeave.archiveDateFormat": {
          "type": "string",
          "default": "YYYY-MM-DDTHH-mm-ss"
        },
        "sheepWeave.ai.enabled": {
          "type": "boolean",
          "default": true
        },
        "sheepWeave.tikalPath": {
          "type": "string",
          "description": "Path to the Okapi Tikal executable (e.g. tikal.bat). If left empty, it tries to find it in the workspace /okapi/tikal folder.",
          "default": ""
        },
        "sheepWeave.translateTab.fontSize": {
          "type": "number",
          "default": 14,
          "description": "Base font size (in px) for the Translate Tab table."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run build:webview && webpack",
    "watch": "npm run build:webview && webpack --watch",
    "package": "npm run build:webview && webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts",
    "build:webview": "cd webview && npm run build",
    "vsix": "vsce package"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/node": "20.x",
    "@types/vscode": "^1.96.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/vsce": "^3.7.1",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^8.56.0",
    "glob": "^10.3.10",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "difflib-ts": "^1.0.3",
    "sheepshuttle": "file:modules/SheepShuttle",
    "sheep-spindle": "file:modules/SheepSpindle/pkg",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "xml2js": "^0.6.2"
  }
}